{
    "manifest_version": 3,
    "name": "Last.fm → Spotify Play Buttons",
    "version": "0.4.0",
    "description": "Replace Last.fm play buttons with Spotify controls; auto-play the matched result on Spotify.",
    "browser_specific_settings": {
        "gecko": {
            "id": "lastfm-spotify-play-buttons@acestronautical",
            "strict_min_version": "121.0"
        }
    },
    "permissions": ["tabs", "storage"],
    "host_permissions": [
        "*://www.last.fm/*",
        "*://open.spotify.com/*"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Last.fm → Spotify Play Buttons",
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["*://www.last.fm/*"],
            "js": [
                "content/bridge.js",
                "content/lastfm-inject.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        },
        {
            "matches": ["*://open.spotify.com/search/*"],
            "js": [
                "content/bridge.js",
                "content/spotify-puppeteer.js"
            ],
            "run_at": "document_idle",
            "all_frames": false
        }
    ]
}
